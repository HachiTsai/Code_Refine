  "parameter_dictionary": {
    "description": "Standard parameter codes used in GMS destination strings (e.g., LP019PLS03)",
    "suffixes": {
      "P": { "full_name": "Proportional Band", "unit": "%", "description": "PID proportional gain" },
      "I": { "full_name": "Integral Time", "unit": "sec", "description": "PID integral reset time" },
