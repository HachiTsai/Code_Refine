{
  "meta": {
    "system": "Hitachi EX-N01",
    "module": "SLC-BLS",
    "version": "1.0"
  },
  "operators": {
    "assignment": {
      "symbol": "=",
      "desc": "代入"
    },
    "arithmetic": [
      {
        "symbol": "+",
        "desc": "加算"
      },
      {
        "symbol": "-",
        "desc": "減算"
      },
      {
        "symbol": "*",
        "desc": "乘算"
      },
      {
        "symbol": "/",
        "desc": "除算"
      },
      {
        "symbol": "%",
        "desc": "餘數運算"
      }
    ],
    "logic": [
      {
        "symbol": "&",
        "desc": "AND 論理積"
      },
      {
        "symbol": "|",
        "desc": "OR 論理和"
      },
      {
        "symbol": "^",
        "desc": "EOR 排他論理和"
      },
      {
        "symbol": "!",
        "desc": "NOT 論理否定"
      }
    ],
    "comparison": [
      {
        "symbol": "==",
        "desc": "一致"
      },
      {
        "symbol": "<>",
        "desc": "不一致"
      },
      {
        "symbol": "<",
        "desc": "小於"
      },
      {
        "symbol": ">",
        "desc": "大於"
      },
      {
        "symbol": "<=",
        "desc": "小於等於"
      },
      {
        "symbol": ">=",
        "desc": "大於等於"
      }
    ]
  },
  "functions": {
    "TIM": {
      "syntax": "a = TIM",
      "desc": "設定實時刻 (時, 分)"
    },
    "DAT": {
      "syntax": "a = DAT",
      "desc": "設定實日期 (年, 月, 日)"
    },
    "BCDF": {
      "syntax": "a = BCDF(b, n)",
      "desc": "BCD 轉二進位 (n位數)"
    },
    "FBCD": {
      "syntax": "a = FBCD(b, n)",
      "desc": "二進位轉 BCD (n位數)"
    },
    "CLR": {
      "syntax": "a = CLR(n)",
      "desc": "清除 n 個端子為 0"
    },
    "LDD": {
      "syntax": "a = LDD(b)",
      "desc": "載入連續 2 語內容"
    },
    "STD": {
      "syntax": "a = STD(b)",
      "desc": "儲存連續 2 語內容"
    },
    "LTM": {
      "syntax": "a = LTM(n)",
      "desc": "設定 Logging 用時間數據"
    },
    "SET": {
      "syntax": "a = SET(m, n)",
      "desc": "將數據 m 設定到 n 個端子"
    },
    "UNIT": {
      "syntax": "a = UNIT(b)",
      "desc": "工業單位變換 (浮點數)"
    },
    "RUNIT": {
      "syntax": "a = RUNIT(b)",
      "desc": "工業單位逆變換 (內部表現)"
    },
    "LOG": {
      "syntax": "a = LOG(b)",
      "desc": "常用對數 (Log10)"
    },
    "LOGN": {
      "syntax": "a = LOGN(b)",
      "desc": "自然對數 (Ln)"
    },
    "INDEX": {
      "syntax": "a = INDEX(b, c)",
      "desc": "指數運算 (b^c)"
    },
    "BLS": {
      "syntax": "BLS(m, d)",
      "desc": "執行指定編號 d 的 BLS 式"
    },
    "JKN": {
      "syntax": "JKN(d)",
      "desc": "執行指定編號 d 的控制條件式"
    }
  },
  "control_statements": {
    "IF": {
      "syntax": "IF...THEN...ELSE",
      "desc": "條件分支 (不可巢狀)"
    },
    "FOR": {
      "syntax": "FOR I = m TO n...NEXT I",
      "desc": "重複執行 (不可巢狀)"
    },
    "GOTO": {
      "syntax": "GOTO n",
      "desc": "跳轉至 Statement n (僅限往前跳)"
    },
    "RTN": {
      "syntax": "RTN",
      "desc": "結束運算式執行"
    },
    "END": {
      "syntax": "END",
      "desc": "程式結束標記"
    }
  }
}