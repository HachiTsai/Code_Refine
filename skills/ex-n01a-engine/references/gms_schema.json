      "DH": { "full_name": "Deviation High Alarm", "unit": "EU", "description": "High deviation threshold from SV" },
      "DL": { "full_name": "Deviation Low Alarm", "unit": "EU", "description": "Low deviation threshold from SV" },
      "MH": { "full_name": "MV High Limit", "unit": "%", "description": "Maximum manipulation value output" },
      "ML": { "full_name": "MV Low Limit", "unit": "%", "description": "Minimum manipulation value output" },
      "PH": { "full_name": "PV High Alarm", "unit": "EU", "description": "Process value high threshold" },
      "PL": { "full_name": "PV Low Alarm", "unit": "EU", "description": "Process value low threshold" },
      "HH": { "full_name": "PV High-High Alarm", "unit": "EU", "description": "Critical process high threshold" },
      "LL": { "full_name": "PV Low-Low Alarm", "unit": "EU", "description": "Critical process low threshold" },
      "SV": { "full_name": "Set Value", "unit": "EU", "description": "Target control value" }
    }
  },
