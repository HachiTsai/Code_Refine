{
  "meta": {
    "system": "Hitachi EX-N01",
    "module": "SLC-VMD",
    "description": "Virtual Machine Device (Valve, Motor, Switch, Selector) Specifications",
    "source_documents": [
      "6_SEL.md",
      "6_Valve_Motor.md",
      "6_VMD.md"
    ]
  },
  "valve_motor": {
    "capacity_per_mlc": 992,
    "types": {
      "1": {
        "name": "Single-acting Valve (單動形閥門)",
        "control_output": "1 DO (Open or Close)",
        "feedback_input": "0-2 DI (Open/Close Limit)"
      },
      "2": {
        "name": "Double-acting Valve (複動形閥門)",
        "control_output": "2 DO (Independent Open/Close)",
        "feedback_input": "0-2 DI (Open/Close Limit)"
      },
      "3": {
        "name": "Direct Motor (直接取合馬達)",
        "control_output": "1 DO (Run)",
        "feedback_input": "0-1 DI (Run Answer)"
      },
      "4": {
        "name": "Pulse Motor (脈衝取合馬達)",
        "control_output": "2 DO (Pulse Start/Stop)",
        "feedback_input": "0-1 DI (Run Answer)"
      }
    },
    "status_bits": {
      "VS": "Simulation Mode (模擬模式)",
      "VD": "Driving Mode (動作中模式)",
      "VI": "Interlock State (互鎖狀態)",
      "VR": "Remote/Local Mode (遠程/本地模式)"
    },
    "alarm_bits": {
      "YE": "Stall Check Abnormal (卡滯檢查異常)",
      "VE": "Congestion Check Abnormal (沖撞檢查異常)"
    },
    "default_constants": {
      "simulation_time_constant": "10 sec"
    }
  },
  "switch": {
    "capacity_per_mlc": 992,
    "types": {
      "1": "One-shot (脈衝輸出)",
      "2": "ON/OFF (保持狀態)"
    },
    "features": {
      "protect": "Guard Mark (防護標記) support"
    }
  },
  "selector": {
    "capacity_per_mlc": 96,
    "max_notches": 16,
    "logic": "Exclusive (Only 1 notch ON at a time)",
    "addressing": "Sequential IN signal allocation from start address"
  }
}
