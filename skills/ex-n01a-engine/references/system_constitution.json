{
  "system": "Hitachi EX-N01A",
  "version": "1.0",
  "description": "Standard System Specifications (Memory, IO, and Constraints)",
  "address_spaces": {
    "analog": {
      "AI": { "range": "AI0000-AI1999", "description": "Process Input Signal" },
      "AO": { "range": "AO0000-AO0999", "description": "Process Output Signal" },
      "GS": { "range": "GS0000-GS1999", "description": "General Storage (1-word)" },
      "GL": { "range": "GL0000-GL0999", "description": "General Long Storage (2-words)" },
      "GR": { "range": "GR0000-GR1279", "description": "Grade Setting Data" },
      "WQ": { "range": "WQ0000-WQ3199", "description": "Grade Reservation Data" },
      "DS": { "range": "DS0000-DS3999", "description": "Recipe Data Setting Terminal" }
    },
    "digital": {
      "DI": { "range": "DI0000-DI3999", "description": "Digital Input Signal" },
      "DO": { "range": "DO0000-DO3999", "description": "Digital Output Signal" },
      "IN": { "range": "IN0000-IN3999", "description": "Internal Switch" },
      "OG": { "range": "OG0000-OG1999", "description": "Operator Guide Signal" },
      "UA": { "range": "UA0000-UA1999", "description": "User Alarm Signal" },
      "EV": { "range": "EV0000-EV1999", "description": "Event Signal" },
      "BL": { "range": "BL0001-BL0256", "description": "BLS Control Signal" },
      "SB": { "range": "SB0000-SB3999", "description": "Data Setting Signal (Handshake for DS)" }
    }
  },
  "memory_layouts": {
    "GMS_GRADE_REGISTER": {
      "block_size_words": 40,
      "offsets": {
        "0": "GRADE_NO",
        "2": "GRADE_NAME_ASCII_1",
        "3": "GRADE_NAME_ASCII_2",
        "4": "GRADE_NAME_ASCII_3",
        "5": "GRADE_NAME_ASCII_4",
        "6": "LOT_NAME_ASCII_1",
        "12": "PRODUCTION_AMOUNT",
        "13": "SUB_DATA_1",
        "14": "SUB_DATA_2",
        "18": "GMS_MGMT_GROUP",
        "19": "CATEGORY_NO",
        "20": "NEXT_GRADE_NO",
        "22": "NEXT_GRADE_NAME_ASCII_1"
      }
    },
    "GMS_WAIT_QUEUE": {
      "block_size_words": 20,
      "offsets": {
        "0": "GRADE_NO",
        "2": "GRADE_NAME_ASCII_1",
        "6": "LOT_NAME_ASCII_1",
        "12": "PRODUCTION_AMOUNT"
      }
    },
    "ALM_USER_ALARM": {
      "block_size_words": 16,
      "offsets": {
        "0": "TAG_NO",
        "Cause": "CAUSE_NAME",
        "Level": "CRITICALITY"
      }
    }
  },
  "system_limits": {
    "max_loops": 768,
    "max_sequences": 333,
    "max_bls_equations": 256,
    "max_vmd_devices": 992,
    "max_selectors": 96
  }
}
