{
  "metadata": {
    "version": "1.1",
    "system": "Hitachi EX-N01A",
    "description": "Comprehensive Consolidated Grammar and Specifications for DDC, SEQ, BLS, VMD, SEL, and ALM/OG modules.",
    "last_updated": "2026-02-04"
  },
  "DDC": {
    "instrument_types": {
      "C": "調節計 (Controller)",
      "I": "警報計 (Indicator)",
      "H": "手動操作器 (Hand Station)",
      "S": "ON-OFF 調節計 (2 值)",
      "F": "ON-OFF 調節計 (3 值)",
      "A": "類比積算計",
      "Q": "脈衝積算計",
      "V": "電動閥操作器 (3 Notch)",
      "B": "批次計數器儀表",
      "P": "脈衝寬度調節計",
      "E": "電動閥控制儀表",
      "G": "品種設定器",
      "U": "品種預約器"
    },
    "loop_status_flags": {
      "LC": "Cascade Mode ON",
      "LA": "Auto Mode ON",
      "LM": "Manual Mode ON",
      "MK": "Alarm Mask ON",
      "SN": "Simulation Mode ON",
      "CB": "Calibration Mode ON",
      "IL": "Isolation Mode ON"
    },
    "loop_alarm_types": {
      "IE": "Instrument Error (儀表異常)",
      "HH": "High-High Alarm (上上限)",
      "LL": "Low-Low Alarm (下下限)",
      "PH": "High Alarm (上限)",
      "PL": "Low Alarm (下限)",
      "DH": "Deviation High Alarm (偏差上限)",
      "DL": "Deviation Low Alarm (偏差下限)"
    },
    "control_signals_from_seq": {
      "SV": "Setpoint Switching",
      "FMV": "Fixed MV Output Force",
      "IRS": "External Integral Separation",
      "BP": "Bumpless Transfer Command",
      "TR": "PV Tracking Command",
      "BS/BR": "Batch Start/Reset"
    }
  },
  "SEQ": {
    "always_logic_codes": {
      "1": "AND (Combine current OR group with subsequent input)",
      "2": "OR_START (Start a new OR group)",
      "3": "NOT_GLOBAL (Negate the entire block result if in start line)",
      "A": "OR_CONTINUE (Add input to current OR group)",
      "B": "OR_END (Last member of an OR group)",
      "C": "TERMINATOR (Explicitly end the logic scan for the line)",
      "D": "DIRECT (Direct assignment/connection)",
      "E": "FANOUT_START (First output of multiple outputs)",
      "F": "FANOUT_FOLLOW (Second output of multiple)",
      "G": "FANOUT_FOLLOW (Third output of multiple)"
    },
    "map_control_terminals": {
      "QP": "Execution Abort (Forced back to Step 01 and Stop)",
      "QR": "Reset (Forced back to Step 01 and Restart)",
      "QH": "Hold (Pause condition judgment)",
      "QA": "Auto Mode",
      "QS": "Semi-Auto Mode",
      "QM": "Manual Mode",
      "QD": "Step Advance (Manual)",
      "QI": "Single Instruction Step",
      "QK": "Interrupted Output Pattern Force",
      "QU": "Step Up Pulse (1-cycle pulse on transition)"
    },
    "output_patterns": {
      "1": "ON / Execute",
      "0": "OFF / Stop",
      "P": "One-shot (ON for 1 control cycle)",
      "*": "Don't Care (Hold previous state)"
    }
  },
  "BLS": {
    "operators": {
      "assignment": "=",
      "arithmetic": [
        "+",
        "-",
        "*",
        "/",
        "%"
      ],
      "logic": [
        "& (AND)",
        "| (OR)",
        "^ (EOR)",
        "! (NOT)"
      ],
      "comparison": [
        "<",
        ">",
        "<=",
        ">=",
        "<>",
        "=="
      ]
    },
    "functions": {
      "UNIT": "Convert to Engineering Unit (Float)",
      "RUNIT": "Convert to Internal Data (0-6000 scale)",
      "TIM": "Set current time (HH:MM) to 2 words",
      "DAT": "Set current date (YY:MM:DD) to 3 words",
      "CLR": "Clear n words to 0",
      "SET": "Set value m to n words",
      "LDD": "Load Double Word",
      "STD": "Store Double Word",
      "LOG": "Common Logarithm (Log10)",
      "INDEX": "Power function (b^c)",
      "BLS": "Execute specified BLS equation",
      "JKN": "Execute Control Condition"
    }
  },
  "VMD_SEL": {
    "vmd_status": {
      "VS": "Simulation Mode",
      "VD": "Driving (In Motion)",
      "VI": "Interlock (Forced State)",
      "VR": "Remote/Local Mode"
    },
    "sel_specs": {
      "capacity_per_mlc": 96,
      "max_notches": 16,
      "logic": "Single-point selection (Only 1 Notch ON)",
      "output": "Automatic consecutive IN signal assignment from start terminal"
    }
  },
  "ALM_OG": {
    "ua_specs": {
      "capacity": 2000,
      "terminal_prefix": "UA",
      "levels": {
        "1": "High Priority (Red)",
        "2": "Medium Priority (Yellow)",
        "3": "Low Priority (White/Info)"
      },
      "source_mapping": "Mapped to DDC/SEQ internal alarm bits or manual trigger."
    },
    "og_specs": {
      "capacity": 2000,
      "terminal_prefix": "OG",
      "max_length": "76 half-width chars",
      "data_codes": {
        "0": "No Data (Text only)",
        "1": "Engineering Unit Data (PV, SV, MV)",
        "2": "Process Name (SEQ Step)",
        "3": "Notch Name (SEL)",
        "4": "Grade Name",
        "5": "Lot Name",
        "6": "ON/OFF Text (User Defined)",
        "7": "Instrument Status (A/M/C/S)"
      }
    }
  },
  "TAG": {
    "file_categories": {
      "aitag": "Analog Input",
      "aotag": "Analog Output",
      "ditag": "Digital Input",
      "dotag": "Digital Output",
      "uatag": "User Alarm",
      "ogtag": "Operation Guide",
      "bltag": "BLS Intermediate Tag",
      "dgtag": "Digital Group Tag"
    },
    "extraction_logic": {
      "bracket_format": {
        "regex": "^\\[(?P<tag_id>[A-Z0-9_-]+)\\](?P<description>.*)$",
        "fields": ["tag_id", "description"]
      },
      "raw_text_format": {
        "regex": "^(?P<description>.*)$",
        "fields": ["description"],
        "note": "Used when ID is sequential (index-based)."
      }
    }
  }
}