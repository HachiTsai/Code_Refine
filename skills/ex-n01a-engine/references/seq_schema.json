{
  "meta": {
    "system": "Hitachi EX-N01",
    "module": "SLC-SEQ",
    "version": "2.2",
    "description": "Sequence Control Specifications and Reverse Engineering Rules",
    "source_documents": [
      "4_SEQ.md",
      "SEQ_Always_Logic_Analysis.md"
    ]
  },
  "specifications": {
    "capacity": {
      "units_per_mlc": 333,
      "timers_counters_per_mlc": 1000,
      "process_per_map": 64,
      "steps_per_map": 128,
      "outputs_per_map": 128
    },
    "cycle_time": {
      "standard": "1.0 sec",
      "high_speed": "0.2 sec"
    }
  },
  "map_definitions": {
    "output_patterns": {
      "1": { "meaning": "ON", "description": "Signal ON or Function Execute" },
      "0": { "meaning": "OFF", "description": "Signal OFF" },
      "2": { "meaning": "Modify Logic", "description": "High priority correction logic for specific steps" },
      "P": { "meaning": "One-shot", "description": "ON for 1 cycle then OFF" },
      "*": { "meaning": "Don't Care", "description": "Hold previous state" }
    },
    "control_terminals": {
      "QP": "Execution Stop (Abort)",
      "QR": "Reset (Return to Step 1)",
      "QH": "Hold (Pause)",
      "QA": "Auto Mode",
      "QS": "Semi-Auto Mode",
      "QM": "Manual Mode",
      "QD": "Step Advance (Manual)",
      "QI": "Single Instruction Step",
      "QK": "Interrupted Output Force",
      "QU": "Step Up Pulse"
    },
    "ddc_signals": {
      "SV": "Setpoint Switching",
      "FMV": "Fixed Manipulated Variable Output",
      "BP": "Bumpless Transfer",
      "TR": "PV Tracking",
      "BS/BR": "Batch Start/Reset"
    }
  },
  "timer_counter_spec": {
    "file_source": "seq_tm.txt",
    "parsing_rules": {
      "fields": ["No", "TAG", "SERVICE", "TMCTSVT", "ADDR"],
      "filter": "Exclude if TAG or SERVICE is empty, '0', or 'W'",
      "prefix_logic": {
        "TD": "Standard Timer (Timer-Down)",
        "TU": "Timer-Up",
        "TH": "Timer-Hold / High-speed"
      }
    }
  },
  "always_logic_rules": {
    "description": "Reverse engineered rules for parsing the <Always> block text format",
    "basic_operators": {
      "AND": "Space (Whitespace)",
      "OR": "+",
      "NOT": "/(Signal)"
    },
    "logic_codes": {
      "1": {
        "type": "AND",
        "action": "Combine current OR group result with subsequent inputs via AND"
      },
      "2": {
        "type": "OR_Start",
        "action": "Start a new OR group"
      },
      "3": {
        "type": "NOT_Global",
        "action": "Negate the entire logic block result"
      },
      "0": {
        "type": "None",
        "action": "Placeholder / No Logic"
      },
      "A": {
        "type": "OR_Continue",
        "action": "Add input to current OR group (more to come)"
      },
      "B": {
        "type": "OR_End",
        "action": "Add input to current OR group and close the group"
      },
      "C": {
        "type": "Terminator",
        "action": "Explicitly end the logic scan for this line"
      },
      "D": {
        "type": "Direct",
        "action": "Direct connection (Assignment)"
      },
      "E": {
        "type": "FanOut_Start",
        "action": "Define logic and assign to first output"
      },
      "F": {
        "type": "FanOut_Follow",
        "action": "Assign previous logic result to second output"
      },
      "G": {
        "type": "FanOut_Follow",
        "action": "Assign previous logic result to third output"
      }
    },
    "parsing_algorithms": {
      "logic_block": "Defined by a line with an OUTPUT. Subsequent lines without OUTPUT belong to this block.",
      "input_negation": "If input starts with '/', treat as NOT(Input).",
      "global_negation": "If code '3' is present in the start line, wrap entire equation in NOT()."
    }
  },
  "execution_order": [
    "1. Initial Start Check",
    "2. Map Status Check (QP -> QR -> QH)",
    "3. Mode Check (A/S/M)",
    "4. Transition Check & Update",
    "5. Correction Logic Execution (Overwrites Pattern)",
    "6. Timer/Counter Update",
    "7. Constant Conditions (Always Block)"
  ]
}
